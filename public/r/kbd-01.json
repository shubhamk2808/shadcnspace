{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "kbd-01",
  "title": "KBD 01 - KBD in Button",
  "description": "Buttons with inline keyboard shortcut hints with Mac/Windows platform switch",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "kbd",
    "button",
    "switch"
  ],
  "files": [
    {
      "path": "src/components/shadcn-space/kbd/kbd-01.tsx",
      "content": "'use client'\n\nimport { useState } from 'react'\nimport { PrinterIcon, SaveIcon, Share2Icon } from 'lucide-react'\nimport { Button } from '@/components/ui/button'\nimport { Kbd, KbdGroup } from '@/components/ui/kbd'\nimport { Switch } from '@/components/ui/switch'\n\ntype Platform = 'mac' | 'win'\n\nconst KbdInButtonDemo = () => {\n  const [platform, setPlatform] = useState<Platform>('mac')\n  const isMac = platform === 'mac'\n\n  return (\n    <div className=\"flex flex-col items-center gap-4\">\n      {/* Platform switch */}\n      <div className=\"flex items-center gap-2 text-sm\">\n        <span className=\"text-muted-foreground\">MacOS</span>\n        <Switch\n          checked={platform === 'win'}\n          onCheckedChange={(checked) => setPlatform(checked ? 'win' : 'mac')}\n        />\n        <span className=\"text-muted-foreground\">Windows</span>\n      </div>\n\n      {/* Buttons */}\n      <div className=\"flex flex-wrap justify-center gap-3\">\n        <Button variant=\"outline\" className=\"hover:bg-muted/40\">\n          <SaveIcon aria-hidden=\"true\" />\n          Save\n          <KbdGroup className=\"-me-1\">\n            <Kbd>{isMac ? '⌘' : 'Ctrl'}</Kbd>\n            <Kbd>S</Kbd>\n          </KbdGroup>\n        </Button>\n\n        <Button variant=\"outline\" className=\"hover:bg-muted/40\">\n          <PrinterIcon aria-hidden=\"true\" />\n          Print\n          <KbdGroup className=\"-me-1\">\n            <Kbd>{isMac ? '⌘' : 'Ctrl'}</Kbd>\n            <Kbd>P</Kbd>\n          </KbdGroup>\n        </Button>\n\n        <Button variant=\"outline\" className=\"hover:bg-muted/40\">\n          <Share2Icon aria-hidden=\"true\" />\n          Share\n          <KbdGroup className=\"-me-1\">\n            <Kbd>{isMac ? '⌘' : 'Ctrl'}</Kbd>\n            <Kbd>{isMac ? '⇧' : 'Shift'}</Kbd>\n            <Kbd>S</Kbd>\n          </KbdGroup>\n        </Button>\n      </div>\n    </div>\n  )\n}\n\nexport default KbdInButtonDemo\n",
      "type": "registry:component",
      "target": "components/shadcn-space/kbd/kbd-01.tsx"
    }
  ],
  "type": "registry:component"
}